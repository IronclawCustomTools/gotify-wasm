{
  "name": "gotify",
  "display_name": "Gotify Notifications",
  "description": "Send push notifications to a self-hosted Gotify server",
  "version": "0.1.0",
  "tools": [
    {
      "name": "gotify_send",
      "description": "Send a push notification via Gotify. Use this to notify the user about completed tasks, alerts, reminders, or any important information.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Notification title. Defaults to 'Kageho' if not provided."
          },
          "message": {
            "type": "string",
            "description": "Notification body text. Supports markdown."
          },
          "priority": {
            "type": "integer",
            "description": "Notification priority: 1-3=low (chat), 5-7=medium (cron/research), 8-10=high (urgent). Defaults to 3.",
            "default": 3
          }
        },
        "required": ["message"]
      }
    }
  ],
  "capabilities": {
    "http": {
      "allowlist": [
        {"host": "gotify.darkc.sobe.world", "path_prefix": "/"}
      ],
      "credentials": {
        "gotify": {
          "secret_name": "gotify_app_token",
          "location": {"type": "header", "name": "X-Gotify-Key"},
          "host_patterns": ["gotify.darkc.sobe.world"]
        }
      }
    },
    "secrets": {
      "allowed_names": ["gotify_app_token", "gotify_url"]
    }
  },
  "setup": {
    "required_secrets": []
  }
}
